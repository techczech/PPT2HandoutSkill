# Source materials (user-specific PowerPoint content)
sourcematerials/

# Generated assets (presentation-specific, created by processMedia.js and init-data.js)
# These are generated from sourcematerials/ during build — never commit them
public/assets/images/slides/
public/assets/images/icons/
public/assets/screenshots/
public/assets/videos/

# Presentation-specific data files (generated per-project by the skill workflow)
# Empty templates are in *.template files; init-data.js copies them on first build
src/data/presentation.json
src/data/entities.json
src/data/sessionInfo.ts
src/data/lectureNotes.ts

# Dependencies
node_modules/

# Build output
dist/

# Local env files
*.local
.env
.env.*

# Editor directories
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# TypeScript cache
*.tsbuildinfo

# Deployment
.vercel
.wrangler
__pycache__/
